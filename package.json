{
  "name": "temp",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:optimized": "vite build --config vite.config.optimized.js",
    "lint": "eslint .",
    "preview": "vite preview",
    "preview:optimized": "vite preview --config vite.config.optimized.js",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:ui": "vitest --ui",
    "optimize-images": "node optimize-images-sharp.js",
    "convert-webp": "node convert-to-webp.js",
    "compress-webp": "node compress-webp-further.cjs",
    "optimize-jpg": "node optimize-jpg-images.cjs",
    "optimize-all": "npm run optimize-images && npm run convert-webp && npm run compress-webp && npm run optimize-jpg",
    "build:prod": "npm run optimize-all && vite build",
    "studio": "npm --prefix studio run dev",
    "studio:deploy": "npm --prefix studio run deploy",
    "studio:seed": "npm --prefix studio run seed"
  },
  "dependencies": {
    "@heroicons/react": "^2.2.0",
    "@sanity/client": "^6.29.1",
    "@vimeo/player": "^2.30.2",
    "formik": "^2.4.6",
    "framer-motion": "^12.16.0",
    "gsap": "^3.13.0",
    "i18next": "^25.2.0",
    "i18next-browser-languagedetector": "^8.1.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-helmet-async": "^2.0.5",
    "react-i18next": "^15.5.1",
    "react-icons": "^5.5.0",
    "react-router-dom": "^7.6.0",
    "sharp": "^0.34.2",
    "split-type": "^0.3.4",
    "styled-components": "^6.1.18",
    "yup": "^1.6.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.25.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "@vitejs/plugin-react": "^4.4.1",
    "@vitest/coverage-v8": "^4.0.18",
    "autoprefixer": "^10.4.21",
    "eslint": "^9.25.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.19",
    "globals": "^16.0.0",
    "jsdom": "^28.0.0",
    "postcss": "^8.5.3",
    "postcss-nested": "^7.0.2",
    "tailwindcss": "^3.3.0",
    "terser": "^5.41.0",
    "vite": "^6.3.5",
    "vitest": "^4.0.18"
  },
  "optionalDependencies": {
    "@rollup/rollup-linux-x64-gnu": "^4.41.0"
  }
}
