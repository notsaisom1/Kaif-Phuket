# KAIF Environment Variables
# Copy this file to .env and fill in real values

# Mapbox API Token (https://mapbox.com)
VITE_MAPBOX_ACCESS_TOKEN=your_mapbox_token_here

# API URL (optional backend)
VITE_API_URL=https://api.yoursite.com

# Environment
VITE_NODE_ENV=production

# Google Analytics ID (optional)
VITE_GA_ID=your_ga_id_here

# Other API keys
VITE_GOOGLE_MAPS_API_KEY=your_google_maps_key_here

# Bitrix24 CRM Integration
VITE_BITRIX24_WEBHOOK_URL=https://your-domain.bitrix24.ru/rest/1/your-webhook-code/

# Sanity CMS (staff admin content)
# Create a project at https://www.sanity.io/manage
VITE_SANITY_PROJECT_ID=your_project_id_here
VITE_SANITY_DATASET=production
VITE_SANITY_API_VERSION=2025-01-01
